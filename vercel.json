{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/lib/(.*)", "destination": "/public/lib/$1" },
    { "source": "/components/(.*)", "destination": "/public/components/$1" },
    { "source": "/pages/(.*)", "destination": "/public/pages/$1" },
    { "source": "/style.css", "destination": "/public/style.css" },
    { "source": "/app.js", "destination": "/public/app.js" },
    { "source": "/favicon.ico", "destination": "/public/favicon.ico" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/generate-sessions",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/expire-passes",
      "schedule": "0 8 * * *"
    }
  ]
}
