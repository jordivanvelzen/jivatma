{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "crons": [
    {
      "path": "/api/cron/generate-sessions",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/expire-passes",
      "schedule": "0 8 * * *"
    }
  ]
}
